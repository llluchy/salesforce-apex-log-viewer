{
  "manifest_version": 3,
  "name": "Salesforce Apex Log Viewer",
  "version": "3.0.0",
  "description": "实时监听和查看 Salesforce Apex Log 的浏览器插件，支持多环境连接",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "cookies",
    "tabs"
  ],
  "host_permissions": [
    "https://*.salesforce.com/*",
    "https://*.salesforce-setup.com/*",
    "https://*.force.com/*",
    "https://*.cloudforce.com/*",
    "https://*.visualforce.com/*",
    "https://*.lightning.force.com/*"
  ],
  "action": {
    "default_title": "打开 Salesforce Apex Log 查看器",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
